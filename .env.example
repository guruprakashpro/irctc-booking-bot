# IRCTC credentials
IRCTC_USERNAME=your_irctc_username
IRCTC_PASSWORD=your_irctc_password

# Telegram Bot (get from @BotFather)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNO-pqrSTUVwxyz

# Payment - stored card last 4 digits for confirmation
IRCTC_CARD_LAST4=1234
IRCTC_CVV=123

# UPI ID for GPay (used for UPI payment option)
UPI_ID=yourname@okicici

# Allowed Telegram user IDs (comma separated) - security: only these users can trigger booking
ALLOWED_TELEGRAM_IDS=123456789,987654321

# Booking defaults
DEFAULT_CLASS=3A
DEFAULT_QUOTA=TATKAL
